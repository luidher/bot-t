{
    "_comentario": "Configuración de selectores CSS para el Modo Autopilot DB. Edita este archivo para adaptar el bot a tu plataforma sin tocar código.",
    "selectors": {
        "question_container":  "ul.form-items > li[data-type='OM'], ul.form-items > li[data-item], .form-items > li[data-type='OM']",
        "question_text":       ".question, .pregunta, p, h2, h3, h4",
        "option_input":        "input[type='radio'], input[type='checkbox']",
        "option_label":        "label",
        "correct_markers": [
            ".correct",
            ".respuesta-correcta",
            ".is-correct",
            "[class*='correct']",
            "[class*='success']",
            ".acert",
            "[class*='acert']"
        ],
        "incorrect_markers": [
            ".incorrect",
            ".respuesta-incorrecta",
            ".is-incorrect",
            "[class*='incorrect']",
            "[class*='wrong']",
            "[class*='error']",
            ".incorrecto",
            "[class*='incorrecto']"
        ],
        "submit_button": [
            "button.btn-submit",
            "button[type='submit'].btn-form",
            "input[type='submit'].btn-submit",
            "button.btn-form.btn-submit",
            "button[type='submit']:not(.btn-reload)"
        ],
        "reload_button": [
            "button.btn-reload",
            "button.btn-form.btn-reload",
            ".reintentar",
            "button[class*='reload']",
            "button[class*='reintentar']",
            "button[class*='retry']"
        ],
        "next_button": [
            ".wrap-footer a",
            "a.btnAccede",
            "a[href*='/MiClase/inicia/']",
            "a[href*='Siguiente']",
            "button.next",
            "a.next",
            "input[type='submit'][value*='iguiente']",
            "button[class*='next']",
            "button[class*='siguiente']",
            ".btn-next",
            ".next-page"
        ],
        "retry_button": [
            "button.btn-reload",
            "button.btn-form.btn-reload",
            "button.retry",
            "a.retry",
            "button[class*='retry']",
            "button[class*='reintentar']",
            ".btn-retry",
            ".reintentar",
            "button[onclick*='reload']"
        ]
    },
    "timings": {
        "feedback_wait_ms":    1500,
        "after_click_wait_ms": 600,
        "reload_wait_ms":      2500,
        "next_wait_ms":        3000,
        "dom_stable_wait_ms":  700,
        "after_submit_wait_ms": 2000
    },
    "auth": {
        "wait_for_manual_auth": true,
        "manual_auth_timeout_sec": 300,
        "manual_auth_poll_sec": 1.0
    },
    "limits": {
        "max_sheets":                   10000,
        "max_intentos_por_pregunta":    8,
        "max_rondas_por_hoja":          20
    },
    "browser": {
        "keep_open": false,
        "pw_timeout_ms": 120000
    }
}
